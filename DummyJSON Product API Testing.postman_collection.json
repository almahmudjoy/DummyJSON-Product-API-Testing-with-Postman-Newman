    {
      "name": "Auth APIs",
      "item": [
        {
          "name": "Login user and save tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login successful\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Access token exists\", function () {\r",
                  "    pm.expect(res).to.have.property(\"accessToken\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Refresh token exists\", function () {\r",
                  "    pm.expect(res).to.have.property(\"refreshToken\");\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"accessToken\", res.accessToken);\r",
                  "pm.environment.set(\"refreshToken\", res.refreshToken);\r",
                  "pm.environment.set(\"userId\", res.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"{{username}}\",\r\n    \"password\": \"{{password}}\",\r\n    \"expiresInMins\": 30\r\n}",
